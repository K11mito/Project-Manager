{
  "name": "side-project-manager",
  "version": "1.0.0",
  "description": "Personal war room dashboard for side projects",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "dist": "electron-builder --mac",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "extends": null,
    "appId": "com.sideprojects.manager",
    "productName": "Side Project Manager",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "assets/icon.icns",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Side Project Manager uses the microphone for clap-to-open detection."
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "clap-listener.js",
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "asar": true
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fontsource/dm-sans": "^5.0.0",
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@octokit/rest": "^20.0.0",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3",
    "openai": "^6.33.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
